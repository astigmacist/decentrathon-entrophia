# Solana bootstrap (frozen contract)
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_TX_MODE=sync
SOLANA_TX_MAX_AGE_SECONDS=900
USDC_MINT=REPLACE_WITH_DEVNET_USDC_MINT

# Program IDs
RECEIVABLES_PROGRAM_ID=REPLACE_WITH_RECEIVABLES_PROGRAM_ID
TRANSFER_HOOK_PROGRAM_ID=REPLACE_WITH_TRANSFER_HOOK_PROGRAM_ID

# Role wallets
ADMIN_WALLET=REPLACE_WITH_ADMIN_WALLET
VERIFIER_WALLET=REPLACE_WITH_VERIFIER_WALLET
ATTESTOR_WALLET=REPLACE_WITH_ATTESTOR_WALLET
ISSUER_WALLET=REPLACE_WITH_ISSUER_WALLET
INVESTOR_A_WALLET=REPLACE_WITH_INVESTOR_A_WALLET
INVESTOR_B_WALLET=REPLACE_WITH_INVESTOR_B_WALLET

# MVP economics
ASSET_TOKEN_DECIMALS=6
DISCOUNT_BPS=9500
FUNDING_TARGET_BPS=9500
FUNDING_WINDOW_HOURS=48

# Demo script settings
DEMO_API_BASE_URL=http://127.0.0.1:3001/api
DEMO_ASSET_ID=demo-asset-day6
DEMO_POSTGRES_CONTAINER=rwa-postgres
DEMO_POSTGRES_USER=rwa
DEMO_POSTGRES_DB=rwa
